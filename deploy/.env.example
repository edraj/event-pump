# Event Pump configuration (systemd EnvironmentFile, SPEC §13)
# Copy to /etc/eventpump/eventpump.env, chmod 640 root:eventpump.

# --- database (the platform's business database — the outbox lives there) ---
EP_DB_CONNSTRING=Host=127.0.0.1;Username=eventpump;Password=CHANGE_ME;Database=platform

# --- listeners ---
# Public ingestion API (behind nginx; nginx must set X-Real-IP).
EP_LISTEN=http://127.0.0.1:8080
# Internal listener: /internal/v1/events + /metrics. Firewall this port.
EP_INTERNAL_LISTEN=http://127.0.0.1:8081
# Worker /metrics + /healthz.
EP_METRICS_LISTEN=http://127.0.0.1:9090

# --- auth ---
# Client app tokens: app_id:token[,app_id:token...]. Distributed with the
# client apps; they identify and rate-limit, they are not secrets.
EP_CLIENT_TOKENS=webapp:CHANGE_ME_WEB,flutterapp:CHANGE_ME_APP
# Internal producer token — a real secret.
EP_INTERNAL_TOKEN=CHANGE_ME_INTERNAL

# --- web SDK cookie & CORS (SPEC §9.5) ---
# The API MUST be served from a subdomain of the site's registrable domain
# (e.g. collect.example.com) so the SameSite=Lax ep_aid cookie flows.
EP_COOKIE_DOMAIN=.example.com
EP_CORS_ORIGINS=https://www.example.com,https://m.example.com

# --- rate limiting: permits/window_seconds per token ---
EP_RATE_LIMIT=600/60

# --- tracking plan (allowlists + routing + per-destination translations) ---
EP_TRACKING_PLAN=/etc/eventpump/tracking-plan.json

# --- retention (SPEC §11) ---
EP_RETENTION_DAYS=30
EP_RETENTION_DEAD_DAYS=90

# --- client IP handling: raw (default) | geo (pluggable resolver) ---
EP_IP_MODE=raw

# --- worker tuning (defaults shown) ---
#EP_WORKER_POLL_MS=1000
#EP_WORKER_CLAIM_BATCH=50
#EP_WORKER_SEND_CONCURRENCY=4
#EP_WORKER_BACKOFF_BASE_S=30
#EP_WORKER_BACKOFF_CAP_S=3600
#EP_WORKER_MAX_ATTEMPTS=10
#EP_WORKER_BREAKER_THRESHOLD=5
#EP_WORKER_BREAKER_PAUSE_S=120
#EP_WORKER_LEASE_S=300
#EP_SENDER_TIMEOUT_MS=10000

# --- GA4 Measurement Protocol ---
EP_GA4_ENABLED=false
EP_GA4_API_SECRET=
EP_GA4_MEASUREMENT_ID=
# App streams (Firebase) instead of / in addition to web:
#EP_GA4_FIREBASE_APP_ID=
#EP_GA4_ENDPOINT=https://www.google-analytics.com

# --- Amplitude HTTP V2 ---
EP_AMPLITUDE_ENABLED=false
EP_AMPLITUDE_API_KEY=
# EU residency: https://api.eu.amplitude.com/2/httpapi
#EP_AMPLITUDE_ENDPOINT=https://api2.amplitude.com/2/httpapi

# --- MoEngage Data API ---
EP_MOENGAGE_ENABLED=false
EP_MOENGAGE_APP_ID=
EP_MOENGAGE_API_KEY=
# Pick your data center host (api-01 .. api-06):
#EP_MOENGAGE_ENDPOINT=https://api-01.moengage.com

# --- Adjust S2S ---
EP_ADJUST_ENABLED=false
EP_ADJUST_APP_TOKEN=
# S2S security token (dashboard: Protection > S2S Security):
#EP_ADJUST_S2S_TOKEN=
#EP_ADJUST_ENDPOINT=https://s2s.adjust.com/event

# --- Meta CAPI (reference sender; DISABLED by default, SPEC §12) ---
EP_META_ENABLED=false
EP_META_PIXEL_ID=
EP_META_ACCESS_TOKEN=
#EP_META_GRAPH_VERSION=v25.0
#EP_META_TEST_EVENT_CODE=
#EP_META_CONSENT_GATING=false
#EP_META_ACTION_SOURCE=website
