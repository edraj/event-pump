{
  "attributes": {
    "first_name": { "type": "string", "max_length": 128 },
    "last_name":  { "type": "string", "max_length": 128 },
    "email":      { "type": "email",  "max_length": 254 },
    "phone":      { "type": "e164",   "max_length": 16 },
    "gender":     { "type": "enum",   "values": ["male", "female", "other", "unknown"] },
    "city":       { "type": "string", "max_length": 128 }
  },

  "events": {
    "user_signed_up": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "adjust", "meta"],
      "adjust_token": "REPLACE_ME_REGISTRATION",
      "properties": ["user_id", "method", "type"]
    },
    "user_logged_in": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "adjust", "meta"],
      "adjust_token": "REPLACE_ME_LOGIN",
      "properties": ["user_id", "method", "type"]
    },
    "user_logged_out": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": ["reason"]
    },

    "product_viewed": {
      "origin": "client",
      "destinations": ["moengage", "amplitude", "meta"],
      "properties": [
        "product_id", "product_name", "price", "currency",
        "variant_name", "variant_key",
        "category_id", "category_name",
        "brand_id", "brand_name",
        "seller_id", "seller_name",
        "in_stock", "is_favorite", "link", "related_products"
      ]
    },
    "category_viewed": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": ["category_id", "category_name", "link", "click_source", "results_count"]
    },
    "brand_viewed": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": ["brand_id", "brand_name", "link", "click_source"]
    },
    "seller_viewed": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": ["seller_id", "seller_name", "link", "click_source"]
    },
    "collection_viewed": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": ["collection_title", "results_count"]
    },

    "products_searched": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": ["search_term", "results_count"]
    },
    "product_list_filtered": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": [
        "search_term", "brands", "categories", "sellers", "colors", "storages",
        "has_discount", "has_fast_delivery", "has_free_shipping", "results_count"
      ]
    },

    "cart_viewed": {
      "origin": "client",
      "destinations": ["moengage", "amplitude", "meta"],
      "properties": ["products_count", "value", "currency", "products"]
    },
    "product_added": {
      "origin": "client",
      "destinations": ["moengage", "amplitude", "adjust", "meta"],
      "adjust_token": "REPLACE_ME_ADD_TO_CART",
      "properties": [
        "product_id", "product_name", "price", "currency",
        "variant_name", "variant_key",
        "category_id", "category_name",
        "brand_id", "brand_name",
        "seller_id", "seller_name",
        "in_stock", "is_favorite", "link", "quantity"
      ]
    },
    "product_removed": {
      "origin": "client",
      "destinations": ["moengage", "amplitude", "meta"],
      "properties": [
        "product_id", "product_name",
        "variant_name", "variant_key",
        "category_id", "category_name",
        "brand_id", "brand_name",
        "seller_id", "seller_name",
        "is_favorite", "link", "quantity", "value", "currency"
      ]
    },

    "wishlist_viewed": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": ["products_count", "product_ids", "product_names"]
    },
    "product_added_to_wishlist": {
      "origin": "client",
      "destinations": ["moengage", "amplitude", "meta"],
      "properties": [
        "product_id", "product_name", "price", "currency",
        "variant_key", "variant_name",
        "category_id", "category_name",
        "brand_id", "brand_name",
        "seller_id", "seller_name", "link"
      ]
    },
    "product_removed_from_wishlist": {
      "origin": "client",
      "destinations": ["moengage", "amplitude", "meta"],
      "properties": [
        "product_id", "product_name", "price", "currency",
        "variant_key", "variant_name",
        "category_id", "category_name",
        "brand_id", "brand_name",
        "seller_id", "seller_name", "link"
      ]
    },

    "coupon_copied": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": ["coupon_code", "screen", "product_id"]
    },
    "coupon_applied": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": ["coupon_code", "value", "discount_type", "discount_amount"]
    },
    "coupon_removed": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": ["coupon_code"]
    },

    "checkout_started": {
      "origin": "client",
      "destinations": ["moengage", "amplitude", "adjust", "meta"],
      "adjust_token": "REPLACE_ME_CHECKOUT_STARTED",
      "properties": ["value", "products_count", "currency", "products"]
    },
    "shipping_address_viewed": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": ["addresses_count", "default_address_id", "default_state_id", "default_state_name"]
    },
    "shipping_address_selected": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": ["address_id", "state_id", "state_name", "is_default", "is_new"]
    },
    "shipping_method_viewed": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": [
        "sellers_count", "total_shipping_cost",
        "has_fast_delivery", "has_free_shipping",
        "shipping_method_keys", "shipping_costs"
      ]
    },
    "shipping_method_selected": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": [
        "seller_id", "method_key", "cost",
        "min_delivery_days", "max_delivery_days",
        "is_fast_delivery", "is_free_shipping"
      ]
    },
    "payment_method_viewed": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": ["methods_count", "method_keys", "has_installment", "employees_only_methods"]
    },
    "payment_method_selected": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": ["method_key", "method_name", "is_installment", "allows_coupons", "for_employees_only"]
    },
    "order_reviewed": {
      "origin": "client",
      "destinations": ["ga4", "moengage", "amplitude", "meta"],
      "properties": [
        "value", "subtotal", "shipping_cost", "services_cost", "discount_amount",
        "products_count", "sellers_count",
        "has_coupon", "coupon_code", "payment_method", "state_id", "all_in_stock"
      ]
    },
    "order_completed": {
      "origin": "server",
      "destinations": ["ga4", "moengage", "amplitude", "adjust", "meta"],
      "adjust_token": "REPLACE_ME_PURCHASE",
      "properties": [
        "order_id", "value", "currency",
        "subtotal", "shipping_cost", "services_cost", "discount_amount",
        "products_count", "sellers_count",
        "coupon_code", "payment_method", "state_id"
      ]
    },

    "ep_attributes_synced": { "origin": "server", "reserved": true, "destinations": ["moengage_customer"] },
    "first_visit": { "origin": "server", "destinations": ["moengage"] }
  },

