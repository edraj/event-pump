# Event Pump events UI — public exposure behind nginx auth (approved model).
# The query API itself listens only on EP_INTERNAL_LISTEN (127.0.0.1:8081);
# this vhost is the sole public doorway and the auth gate.
#
#   htpasswd -c /etc/nginx/eventpump-ui.htpasswd youruser
#   cp -r ui/dist/client/* /opt/eventpump-ui/

server {
    listen 443 ssl;
    server_name events.example.com;

    # ssl_certificate     /etc/pki/tls/certs/events.example.com.crt;
    # ssl_certificate_key /etc/pki/tls/private/events.example.com.key;

    auth_basic           "Event Pump";
    auth_basic_user_file /etc/nginx/eventpump-ui.htpasswd;

    root /opt/eventpump-ui;

    # read-only query API, proxied to the internal listener
    location /internal/v1/query/ {
        proxy_pass http://127.0.0.1:8081;
        proxy_set_header Host $host;
    }

    # the SPA (history routing: unknown paths fall back to index.html)
    location / {
        try_files $uri /index.html;
    }
}
